{
  "name": "qd-web",
  "version": "1.0.0",
  "description": "QD Systems website + AI chatbot",
  "type": "module",
  "private": true,
  "scripts": {
    "build:kb": "node scripts/build-kb.mjs",
    "scrape:site": "node scripts/scrape-site.mjs",
    "dev": "node _dev-server.mjs",
    "dev:vercel": "vercel dev",
    "deploy": "vercel --prod",
    "build:pricing": "tsc -p app/lib/pricing/tsconfig.json",
    "pretest:pricing": "npm run build:pricing",
    "prepricing": "npm run build:pricing",
    "test:pricing": "node scripts/test-pricing.mjs && node scripts/test-pricing-property.mjs && node scripts/test-pricing-golden.mjs"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.5",
    "firebase-admin": "^12.7.0",
    "googleapis": "^173.0.0",
    "groq-sdk": "^0.7.0",
    "nodemailer": "^8.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cheerio": "^1.0.0",
    "fast-check": "^4.8.0",
    "playwright": "^1.49.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
