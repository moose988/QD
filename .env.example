# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Groq API — get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Firebase Admin — paste the FULL JSON from a service account key file as a single line.
# Generate one at: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# Only needed locally for `npm run build:kb`. In Vercel, paste the same JSON into the dashboard env vars.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"qdsystems-67764", "...": "..."}

# Model choices (optional — defaults shown)
EMBED_MODEL=Xenova/multilingual-e5-base
GROQ_MODEL=llama-3.3-70b-versatile
