# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Groq API — get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_rotated_key_here

# Firebase Admin for quote APIs/admin auth.
# Generate one at: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# Map from the JSON file like this:
#   project_id   -> FIREBASE_PROJECT_ID
#   client_email -> FIREBASE_CLIENT_EMAIL
#   private_key  -> FIREBASE_PRIVATE_KEY
# Keep FIREBASE_PRIVATE_KEY wrapped in quotes and preserve escaped \n characters.
FIREBASE_PROJECT_ID=qdsystems-67764
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@qdsystems-67764.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional legacy/full JSON form still used by `npm run build:kb`.
# Paste the entire service account JSON onto one line if you use that script.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"qdsystems-67764", "...": "..."}

# Model choices (optional — defaults shown)
EMBED_MODEL=Xenova/multilingual-e5-base
GROQ_MODEL=llama-3.3-70b-versatile

# Quotation passcode salt — required by /api/quote-* endpoints.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QUOTE_PASSCODE_SALT=your_random_hex_here
