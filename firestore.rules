rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          'mohammedqudaih107@gmail.com',
          'mdaya0089@gmail.com'
        ];
    }

    function isPublicInvitationRead() {
      return resource.data.active == true;
    }

    function isPublicViewsIncrement() {
      return resource.data.active == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
        && request.resource.data.views == resource.data.views + 1;
    }

    function isPublicRsvpCounterIncrement() {
      return resource.data.active == true
        && resource.data.rsvpEnabled == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpCount'])
        && request.resource.data.rsvpCount == resource.data.rsvpCount + 1;
    }

    function invitationIsActive(invitationPath) {
      return get(invitationPath).data.active == true;
    }

    function invitationRsvpIsEnabled(invitationPath) {
      return get(invitationPath).data.rsvpEnabled == true;
    }

    match /projectSubmissions/{document} {
      allow create: if true;
      allow read, update, delete: if isAllowedAdmin();
    }

    match /reviews/{document} {
      allow read: if true;
      allow write: if isAllowedAdmin();
    }

    match /quotes/{document} {
      allow read, write: if isAllowedAdmin();
    }

    match /cards/{cardId} {
      allow read: if true;
      allow write: if isAllowedAdmin();
    }

    match /chatLeads/{document} {
      allow create: if true;
      allow read, update, delete: if isAllowedAdmin();
    }

    match /bookings/{document} {
      allow create: if true;
      allow read, update, delete: if isAllowedAdmin();
    }

    match /chatConversations/{document} {
      allow create, update: if true;
      allow read, delete: if isAllowedAdmin();

      match /messages/{msg} {
        allow create: if true;
        allow read: if isAllowedAdmin();
      }
    }

    match /adminActivityLogs/{document} {
      allow create: if isAllowedAdmin();
      allow read: if isAllowedAdmin();
      allow update, delete: if false;
    }

    match /clientDemos/{document} {
      allow read, write: if isAllowedAdmin();
    }

    // Primary collection used by the admin invitations tab and public invite pages.
    match /invitations/{invitationId} {
      allow read: if isAllowedAdmin() || isPublicInvitationRead();
      allow create, delete: if isAllowedAdmin();
      allow update: if isAllowedAdmin()
        || isPublicViewsIncrement()
        || isPublicRsvpCounterIncrement();
    }

    // Top-level RSVP collection used by the current invitation flow.
    match /invitationRsvps/{rsvpId} {
      allow read: if isAllowedAdmin();
      allow create: if request.resource.data.inviteId is string
        && request.resource.data.inviteSlug is string
        && request.resource.data.guestName is string
        && request.resource.data.phone is string
        && request.resource.data.attending in ['yes', 'no']
        && invitationIsActive(/databases/$(database)/documents/invitations/$(request.resource.data.inviteId))
        && invitationRsvpIsEnabled(/databases/$(database)/documents/invitations/$(request.resource.data.inviteId));
      allow update, delete: if isAllowedAdmin();
    }

    // Legacy collection kept so older invitation links continue working.
    match /weddingInvitations/{invitationId} {
      allow read: if isAllowedAdmin() || isPublicInvitationRead();
      allow create, delete: if isAllowedAdmin();
      allow update: if isAllowedAdmin()
        || isPublicViewsIncrement()
        || isPublicRsvpCounterIncrement();

      match /rsvps/{rsvpId} {
        allow read: if isAllowedAdmin();
        allow create: if invitationIsActive(/databases/$(database)/documents/weddingInvitations/$(invitationId))
          && invitationRsvpIsEnabled(/databases/$(database)/documents/weddingInvitations/$(invitationId));
        allow update, delete: if false;
      }
    }

    match /businessOutreachLeads/{document} {
      allow read, update, delete: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
